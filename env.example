AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GITHUB_TOKEN=
VERCEL_TOKEN=
NEON_API_KEY=
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
SPACESHIP_DOMAINS=
DATABASE_URL=
NEXT_PUBLIC_APP_URL=

# Optional allowlists for write actions
AWS_MUTABLE_INSTANCE_IDS=
