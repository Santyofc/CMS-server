# Runtime required in production
# Env parser is dotenv-style, one KEY=VALUE per line.
# '&' is safe unquoted.
# Quote values only when they contain spaces, leading/trailing whitespace or literal '#'.
NODE_ENV=production
APP_URL=
NEXT_PUBLIC_APP_URL=
DATABASE_URL=
REDIS_URL=
TRUST_PROXY=true
LOG_LEVEL=info

# Required providers when their modules are enabled
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GITHUB_TOKEN=
VERCEL_TOKEN=
NEON_API_KEY=
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# Optional provider settings
SPACESHIP_DOMAINS=
VERCEL_TEAM_ID=

# Optional allowlists for write actions
AWS_MUTABLE_INSTANCE_IDS=
VERCEL_REDEPLOY_ALLOWLIST=
SPACESHIP_DNS_WRITE_ALLOWLIST=

# Optional CI/CD and deploy flags
GIT_AUTO_PUSH=false
DEPLOY_SCRIPT_PATH=/var/www/cms/scripts/deploy.sh
ENABLE_AUTO_DEPLOY=true
